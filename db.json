    {
      "id": "classic-beef",
      "title": "Classic Beef Burger",
      "steps": [
        {
          "id": "step1",
          "type": "single-select",
          "instruction": "Choose your bun",
          "options": ["Sesame", "Brioche", "Lettuce Wrap"],
          "feedback": null 
        },{
          "id": "step2",
          "type": "multiple-select",
          "instruction": "Choose your toppings",
          "options":["Lettuce", "Tomatoes", "Onions", "Pickles", "Cheese"],
          "feedback": null
        },
        {
          "id":"step3",
          "type": "text",
          "instruction": "Enter number of sauce servings",
          "feedback": {
              "condition": "amount > 3",
              "message": "Too much sauce might overpower the flavor!"
          }
        },
        {
          "id": "step4",
          "type": "image-selection",
