          "imageOptions":[
            { "url": "img/presentation1.jpg", "isCorrect": false },
            { "url": "img/presentation2.jpg", "isCorrect": true },
            { "url": "img/presentation3.jpg", "isCorrect": false }],
          "feedback": null
        },{
          "id": "step5",
          "type": "multiple-select",
          "instruction": "Extra Options",
          "options":[
            {
              "id":"French Fries",
              "cost": "$3.45"
            },
            {
              "id": "Extra Patty",
              "cost": "$2.40"
            }
          ],
          "feedback":{
              "condition": "amount > 4",
              "message": "Too many "
          }
        }
      ]
    },
